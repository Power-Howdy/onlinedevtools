# Base URL for production. Used in sitemap.xml and robots.txt.
# Example: https://onlinedevtools.com
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Optional: Google Analytics 4 ID. Leave empty to disable analytics.
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Optional: GitHub repository URL. Shown in footer when set.
NEXT_PUBLIC_GITHUB_REPO=https://github.com/username/online-dev-tools
